[sub_resource type="Shader" id="Shader_i3jxm"]
code = "shader_type canvas_item;
render_mode unshaded;

uniform vec4 u_color_key : source_color;
uniform vec4 u_replacement_color : source_color;
uniform float strength : hint_range(0.0, 1.0) = 1.0;
uniform float alpha : hint_range(0.0, 1.0) = 1.0;

void fragment() {
    vec4 col = texture(TEXTURE, UV);

    vec3 diff = abs(col.rgb - u_color_key.rgb);
    float d = max(max(diff.r, diff.g), diff.b);

    if (d < 0.01 && col.a > 0.0) {
        col.rgb = u_replacement_color.rgb * strength;
        col.a = alpha;
    }

    COLOR = col;
}"

